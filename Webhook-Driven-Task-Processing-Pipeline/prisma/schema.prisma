// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  sourceSlug  String   @unique
  actionType  String   @default("DEFAULT")
  actionConfig Json?   // Store configuration for different action types
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs        JobLog[]
  subscribers Subscriber[]
}

model Subscriber {
  id         String   @id @default(uuid())
  url        String
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model JobLog {
  id          String    @id @default(uuid())
  pipelineId  String
  bullJobId   String?   @unique // Store BullMQ job ID
  payload     Json
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
  completedAt DateTime?

  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deliveries  DeliveryAttempt[]
}

model DeliveryAttempt {
  id            String   @id @default(uuid())
  jobId         String
  subscriberUrl String
  status        String   // SUCCESS, FAILED
  responseCode  Int?
  responseBody  String?
  errorMessage  String?
  attemptNumber Int
  createdAt     DateTime @default(now())
  
  job           JobLog   @relation(fields: [jobId], references: [id], onDelete: Cascade)
}