{
    "name": "boot-final",
    "version": "1.0.0",
    "type": "module",
    "description": "Backend service with BullMQ and Prisma",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "worker": "node dist/worker.js",
        "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
        "dev:worker": "nodemon --exec node --loader ts-node/esm src/worker.ts",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio",
        "test": "jest --coverage",
        "test:e2e": "jest --config jest.e2e.config.js --runInBand",
        "lint": "eslint src/**/*.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "prisma": "^6.4.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@bull-board/api": "^6.20.6",
        "@bull-board/express": "^6.20.6",
        "@prisma/client": "^6.4.1",
        "axios": "^1.13.6",
        "bullmq": "^5.71.0",
        "express": "^5.2.1",
        "ioredis": "^5.10.1"
    }
}
